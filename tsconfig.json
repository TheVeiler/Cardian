{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "node",
		"allowJs": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"baseUrl": ".",
		"outDir": "dist",
		"types": ["node", "webpack/module"],

		"paths": {
			"/types": ["src/types/index"],
			"/types/*": ["src/types/*"],
			"/common": ["src/common/index"],
			"/common/*": ["src/common/*"],
			"/blackjack": ["src/blackjack/index"],
			"/blackjack/*": ["src/blackjack/*"],
			"/holdem": ["src/holdem/index"],
			"/holdem/*": ["src/holdem/*"],
			"/decklists": ["src/decklists/index"],
			"/decklists/*": ["src/decklists/*"],
			"/Cardian": ["src/Cardian"]
		}
	},
	"files": ["src/Cardian.ts"]
}
